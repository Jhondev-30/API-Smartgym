# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Configuración de la Base de Datos (PostgreSQL)
# Estructura: postgres://usuario:password@host:puerto/nombre_bd
DATABASE_URL=postgres://tu_usuario:tu_password@localhost:5432/smartgym_db

# Seguridad y Autenticación (Requerimiento 2.1)
JWT_SECRET=tu_clave_secreta_para_firmar_tokens
JWT_EXPIRES_IN=24h

# Configuración para Docker (Opcional pero recomendado para el despliegue)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=smartgym_db